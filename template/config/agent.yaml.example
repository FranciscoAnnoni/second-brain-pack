# Second Brain — Agent Configuration
# Auto-generated by install.sh. Edit manually if needed.

agent: gemini           # claude | gemini | other
agent_command: ""       # only used if agent is 'other' (full CLI command)
language: es            # es | en
agent_name: "Aria"      # name shown in SOUL.md
user_name: ""           # your name, used to personalize SOUL.md
vault_path: ""          # absolute path to this vault (auto-set by installer)
obsidian: false         # true if Obsidian is installed and you want vault integration
context_size: compact   # compact (Gemini free, ~500 tokens) | standard (Claude, ~1500 tokens)
